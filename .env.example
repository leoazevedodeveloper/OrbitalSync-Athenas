# ============================================================
# OrbitalSync - .env.example (configuracoes principais)
# ============================================================
# Dica: em producao, mantenha segredos apenas no backend.

# ------------------------------------------------------------
# 1) LLM principal (ATHENAS voice/chat - Gemini Live)
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# Opcional: expoe segredos na UI de Settings (apenas ambiente local)
# NUNCA habilitar em backend exposto na rede.
# ORBITAL_EXPOSE_SECRETS_IN_SETTINGS_UI=1

# ------------------------------------------------------------
# 2) Supabase (config remota + RAG do vault)
# ------------------------------------------------------------
# URL do projeto (Settings -> API -> Project URL)
# SUPABASE_URL=https://xxxx.supabase.co

# Recomendado no backend: service role (bypass RLS)
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Opcional: anon key (somente se suas policies permitirem)
# SUPABASE_ANON_KEY=your_supabase_anon_key

# Forca desabilitar integracao Supabase mesmo com URL/chave preenchidas
# SUPABASE_CONFIG_ENABLED=false

# module_key usado na tabela athena_settings (default: athena)
# ATHENA_SETTINGS_MODULE_KEY=athena

# ------------------------------------------------------------
# 3) RAG do cerebro Obsidian (chunks em Supabase pgvector)
# ------------------------------------------------------------
# Rode no SQL Editor: supabase/athena_brain_chunk_embeddings.sql
# Desliga o pipeline RAG (fica apenas keyword em search_brain)
# ORBITAL_BRAIN_RAG=0

# Tamanho alvo do chunk e sobreposicao (caracteres)
# ORBITAL_BRAIN_RAG_CHUNK_CHARS=1800
# ORBITAL_BRAIN_RAG_CHUNK_OVERLAP=200

# Limite de notas no bloco keyword em search_brain mode hybrid
# BRAIN_RAG_HYBRID_KEYWORD_LIMIT=15

# ------------------------------------------------------------
# 4) ComfyUI (geracao de imagem local)
# ------------------------------------------------------------
COMFYUI_BASE_URL=http://127.0.0.1:2000
# Padrao (se omitido): integrations/comfyui/workflow_api.json
# COMFYUI_WORKFLOW_FILE=C:/caminho/custom/workflow_api.json

# ------------------------------------------------------------
# 5) Integracoes / Webhooks
# ------------------------------------------------------------
# Debug do botao "Testar conexoes"
# ORBITAL_INTEGRATION_TEST_LOG=1

# Evita POST de probe em URLs /webhook/ (usa so HEAD/GET)
# ORBITAL_SKIP_WEBHOOK_POST_PROBE=1

# Hook padrao opcional de Google Calendar (se nao vier do Supabase)
# ATHENA_GOOGLE_CALENDAR_WEBHOOK_URL=https://seu-n8n/webhook/athena-google-calendar

# Desliga injecao do webhook padrao acima
# ORBITAL_DISABLE_DEFAULT_CALENDAR_WEBHOOK=0

# ------------------------------------------------------------
# 6) Docker + Cloudflared no bootstrap (Electron/local) - opcional
# ------------------------------------------------------------
# `docker start` ao abrir o OrbitalSync (antes do tunel). Nao para ao fechar o app.
# Com Docker Desktop fechado no Windows: o Electron tenta abrir o Docker Desktop e espera o daemon.
# ORBITAL_SKIP_DOCKER_START=1
# ORBITAL_DOCKER_CONTAINERS=n8n
# Varios: ORBITAL_DOCKER_CONTAINERS=n8n,outro_container

# Nao abrir o Docker Desktop automaticamente (falha se daemon estiver parado)
# ORBITAL_START_DOCKER_DESKTOP=0
# ORBITAL_DOCKER_DESKTOP_EXE=C:/Program Files/Docker/Docker/Docker Desktop.exe
# ORBITAL_DOCKER_WAIT_MS=180000

# Se o Electron nao encontrar `docker` no PATH, force o executavel
# ORBITAL_DOCKER_CLI=C:/Program Files/Docker/Docker/resources/bin/docker.exe

# Ao fechar o OrbitalSync, para os mesmos containers (default: nao)
# ORBITAL_DOCKER_STOP_ON_QUIT=1

# Cloudflared
# ORBITAL_SKIP_CLOUDFLARED=1
# CLOUDFLARED_TUNNEL=n8n
# CLOUDFLARED_EXE=C:/caminho/cloudflared.exe

# ------------------------------------------------------------
# Observacoes
# ------------------------------------------------------------
# - O Electron (main.js) carrega este .env na raiz do repo.
# - Credenciais tambem podem ser salvas em data/local_credentials.json via UI.
# - local_credentials.json sobrepoe o .env nas chaves presentes.
