GEMINI_API_KEY=your_key_here

# Opcional: enviar SUPABASE_SERVICE_ROLE_KEY e GEMINI_API_KEY ao formulário das Configurações (Socket.IO).
# Por defeito esses campos ficam vazios na UI mesmo com .env preenchido — o backend usa na mesma as variáveis.
# Só liga em máquina local / Electron; não uses com backend exposto na rede.
# ORBITAL_EXPOSE_SECRETS_IN_SETTINGS_UI=1

# Credenciais também podem ser definidas na UI (cartões do hub e data/local_credentials.json).
# Podes editar este ficheiro direto em Configurações → «Ficheiro .env (avançado)»; ao gravar cria-se .env.bak.
# local_credentials.json sobrepõe o .env para as variáveis que lá estiverem.

# Electron: túnel Cloudflare ao abrir a app (ambiente/cloudflared.exe, cwd ambiente/)
# ORBITAL_SKIP_CLOUDFLARED=1
# CLOUDFLARED_TUNNEL=n8n
# CLOUDFLARED_EXE=C:/caminho/cloudflared.exe

# Logs no consola ao clicar «Testar conexões» (cada webhook: HEAD/GET e URL truncada)
# ORBITAL_INTEGRATION_TEST_LOG=1
# Desligar POST de probe em URLs /webhook/ (só HEAD/GET)
# ORBITAL_SKIP_WEBHOOK_POST_PROBE=1

# ComfyUI local (geração de imagem quando workflow_api.json existir em data/comfyui/)
COMFYUI_BASE_URL=http://127.0.0.1:2000
# COMFYUI_WORKFLOW_FILE=C:/caminho/custom/workflow_api.json

# --- Supabase: com URL + chave, o backend usa SÓ o banco (sem ler config/*.json) e grava alterações na hora ---
# URL do projeto (Settings → API → Project URL)
# SUPABASE_URL=https://xxxx.supabase.co
# Chave com bypass de RLS — use SOMENTE no servidor, nunca no front/Electron
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Alternativa: anon key (só funciona se as tabelas tiverem políticas RLS de leitura para anon)
# SUPABASE_ANON_KEY=your_anon_key
# Forçar desligar mesmo com variáveis setadas:
# SUPABASE_CONFIG_ENABLED=false
# Módulo em athena_settings (coluna module_key), default athena
# ATHENA_SETTINGS_MODULE_KEY=athena
