# ============================================================
# OrbitalSync - .env.example (configurações principais)
# ============================================================
# Dica: em produção, mantenha segredos só no backend.

# ------------------------------------------------------------
# 1) LLM principal (ATHENAS voice/chat - Gemini Live)
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# Opcional: expõe segredos na UI de Settings (apenas local)
# NUNCA habilitar em backend exposto na rede.
# ORBITAL_EXPOSE_SECRETS_IN_SETTINGS_UI=1

# ------------------------------------------------------------
# 2) Supabase (config remota + histórico + embeddings)
# ------------------------------------------------------------
# URL do projeto (Settings -> API -> Project URL)
# SUPABASE_URL=https://xxxx.supabase.co

# Recomendado no backend: service role (bypass RLS)
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Opcional: anon key (somente se suas policies permitirem)
# SUPABASE_ANON_KEY=your_supabase_anon_key

# Forçar desabilitar integração Supabase mesmo com URL/chave preenchidas
# SUPABASE_CONFIG_ENABLED=false

# module_key usado na tabela athena_settings (default: athena)
# ATHENA_SETTINGS_MODULE_KEY=athena

# ------------------------------------------------------------
# 3) Gate de memória remota (Supabase selective memory) - OLLAMA
# ------------------------------------------------------------
# Se "on" (default): classifica cada mensagem antes de enviar para memória remota
# ORBITAL_MEMORY_OLLAMA_GATE=on

# Compat legado (se estiver off, também desliga o gate)
# ORBITAL_MEMORY_GEMINI_GATE=on

# Se "on": desliga filtro e envia tudo para remoto
# ORBITAL_MEMORY_FULL_REMOTE=off

# Modelo usado no gate de memória (Ollama)
ORBITAL_MEMORY_GATE_MODEL=qwen2.5:7b
# Alias aceito também:
# ORBITAL_MEMORY_OLLAMA_MODEL=qwen2.5:7b

# URL do Ollama local
ORBITAL_MEMORY_OLLAMA_URL=http://127.0.0.1:11434

# Robustez da chamada ao Ollama
ORBITAL_MEMORY_GATE_RETRIES=3
ORBITAL_MEMORY_GATE_TIMEOUT_SEC=20

# Logs detalhados da decisão de memória (debug)
# ORBITAL_MEMORY_SALIENCE_DEBUG=0

# ------------------------------------------------------------
# 4) Memória semântica / embeddings (Supabase + Gemini embedding)
# ------------------------------------------------------------
# Liga/desliga busca semântica no histórico
# ORBITAL_CHAT_SEMANTIC=1

# Liga/desliga geração automática de embeddings
# ORBITAL_EMBED_INDEX=1

# Quem entra no índice: "*" ou "User, ATHENAS"
# ORBITAL_EMBED_SENDERS=*

# Tamanho mínimo de texto para indexar
# ORBITAL_EMBED_MIN_LENGTH=24

# Máximo de caracteres enviados para embedding
# ORBITAL_EMBED_MAX_CHARS=8000

# Quantas mensagens recentes entram no startup/reconnect do chat Live
# ORBITAL_CHAT_STARTUP_CONTEXT_LIMIT=100

# ------------------------------------------------------------
# 4b) RAG do cérebro Obsidian (chunks em Supabase pgvector)
# ------------------------------------------------------------
# Rode no SQL Editor: supabase/athena_brain_chunk_embeddings.sql
# Desliga o pipeline RAG (só keyword em search_brain)
# ORBITAL_BRAIN_RAG=0
# Tamanho alvo do chunk e sobreposição (caracteres)
# ORBITAL_BRAIN_RAG_CHUNK_CHARS=1800
# ORBITAL_BRAIN_RAG_CHUNK_OVERLAP=200
# Limite de notas no bloco keyword em search_brain mode hybrid (default no settings: 15)
# BRAIN_RAG_HYBRID_KEYWORD_LIMIT=15

# ------------------------------------------------------------
# 5) ComfyUI (geração de imagem local)
# ------------------------------------------------------------
COMFYUI_BASE_URL=http://127.0.0.1:2000
# Padrão (se omitido): integrations/comfyui/workflow_api.json
# COMFYUI_WORKFLOW_FILE=C:/caminho/custom/workflow_api.json

# ------------------------------------------------------------
# 6) Integrações / Webhooks
# ------------------------------------------------------------
# Debug do botão "Testar conexões"
# ORBITAL_INTEGRATION_TEST_LOG=1

# Evita POST de probe em URLs /webhook/ (usa só HEAD/GET)
# ORBITAL_SKIP_WEBHOOK_POST_PROBE=1

# Hook padrão opcional de Google Calendar (se não vier do Supabase)
# ATHENA_GOOGLE_CALENDAR_WEBHOOK_URL=https://seu-n8n/webhook/athena-google-calendar

# Desliga injeção do webhook padrão acima
# ORBITAL_DISABLE_DEFAULT_CALENDAR_WEBHOOK=0

# ------------------------------------------------------------
# 7) Finance (Pierre) - opcional
# ------------------------------------------------------------
# PIERRE_API_KEY=your_pierre_api_key
# PIERRE_BASE_URL=https://www.pierre.finance
# PIERRE_TIMEOUT_SECONDS=15
# PIERRE_MANUAL_UPDATE_TIMEOUT_SECONDS=120
# PIERRE_POST_SYNC_WAIT_SECONDS=6
# PIERRE_POST_SYNC_EXTRA_WAIT_INPROGRESS=2.5
# PIERRE_POST_SYNC_WAIT_MAX=45
# PIERRE_FOLLOW_UP_SNAPSHOT_SECONDS=14

# ------------------------------------------------------------
# 8) Docker + Cloudflared no bootstrap (Electron/local) - opcional
# ------------------------------------------------------------
# `docker start` ao abrir o OrbitalSync (antes do túnel). Não para ao fechar o app.
# Com Docker Desktop fechado no Windows: o Electron tenta abrir o Docker Desktop e espera o daemon.
# ORBITAL_SKIP_DOCKER_START=1
# ORBITAL_DOCKER_CONTAINERS=n8n
# Vários: ORBITAL_DOCKER_CONTAINERS=n8n,outro_container
# Não abrir o Docker Desktop automaticamente (só falha se o daemon já estiver parado):
# ORBITAL_START_DOCKER_DESKTOP=0
# ORBITAL_DOCKER_DESKTOP_EXE=C:/Program Files/Docker/Docker/Docker Desktop.exe
# ORBITAL_DOCKER_WAIT_MS=180000
# Se o OrbitalSync não encontrar `docker` (PATH do Electron ≠ PowerShell), força o executável:
# ORBITAL_DOCKER_CLI=C:/Program Files/Docker/Docker/resources/bin/docker.exe
# Ao fechar o OrbitalSync, parar os mesmos containers (default: não — o n8n fica a correr):
# ORBITAL_DOCKER_STOP_ON_QUIT=1
# ORBITAL_SKIP_CLOUDFLARED=1
# Não iniciar `ollama serve` junto com o Electron (e não encerre Ollama ao fechar o app)
# ORBITAL_SKIP_OLLAMA=1
# CLOUDFLARED_TUNNEL=n8n
# CLOUDFLARED_EXE=C:/caminho/cloudflared.exe

# ------------------------------------------------------------
# Observações
# ------------------------------------------------------------
# - O Electron (main.js) carrega este .env na raiz do repo (não sobrescreve variáveis já definidas no Windows).
# - Credenciais também podem ser salvas em data/local_credentials.json via UI.
# - local_credentials.json sobrepõe o .env nas chaves presentes.
