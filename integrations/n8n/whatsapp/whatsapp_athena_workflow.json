    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// â”€â”€ Outgoing: ATHENAS envia mensagem proativamente â”€â”€\nconst root = $input.first().json || {};\nconst body = root.body && typeof root.body === 'object' ? root.body : root;\n\n// Health check\nif (String(body.action || '') === '__orbital_connectivity_probe__') {\n  return [{ json: { ok: true, probe: true } }];\n}\n\nconst phone = String(body.phone || body.number || body.to || '').trim();\nconst text = String(body.text || body.message || body.content || '').trim();\nconst instance = String(body.instance || '').trim();\n\nif (!phone) throw new Error('phone/number/to Ã© obrigatÃ³rio');\nif (!text) throw new Error('text/message/content Ã© obrigatÃ³rio');\n\nreturn [{ json: { phone, text, instance } }];\n"
      },
