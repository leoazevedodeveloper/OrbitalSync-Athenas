    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// â”€â”€ Parse Evolution API incoming message â”€â”€\nconst root = $input.first().json || {};\nconst body = root.body && typeof root.body === 'object' ? root.body : root;\n\n// Evolution API v2 format\nconst data = body.data || body;\nconst event = body.event || '';\n\n// SÃ³ processa messages.upsert\nif (event && event !== 'messages.upsert') {\n  return [{ json: { skip: true, reason: 'not a message event: ' + event } }];\n}\n\nconst key = data.key || {};\nif (key.fromMe === true) {\n  return [{ json: { skip: true, reason: 'own message (fromMe)' } }];\n}\n\nconst remoteJid = key.remoteJid || '';\nif (remoteJid.endsWith('@g.us') || remoteJid.includes('broadcast')) {\n  return [{ json: { skip: true, reason: 'group or broadcast' } }];\n}\n\nconst phone = remoteJid.replace('@s.whatsapp.net', '').replace('@c.us', '');\n\nconst msg = data.message || {};\nconst text = msg.conversation\n  || (msg.extendedTextMessage && msg.extendedTextMessage.text)\n  || (msg.imageMessage && msg.imageMessage.caption)\n  || (msg.videoMessage && msg.videoMessage.caption)\n  || '';\n\nif (!text.trim()) {\n  return [{ json: { skip: true, reason: 'no text content' } }];\n}\n\nconst pushName = data.pushName || phone;\nconst ts = Number(data.messageTimestamp || 0);\nconst dateObj = ts ? new Date(ts * 1000) : new Date();\nconst tz = 'America/Sao_Paulo';\nconst dateParts = dateObj.toLocaleDateString('pt-BR', { timeZone: tz }).split('/');\nconst dateStr = `${dateParts[2]}-${dateParts[1].padStart(2,'0')}-${dateParts[0].padStart(2,'0')}`;\nconst timeStr = dateObj.toLocaleTimeString('pt-BR', { timeZone: tz, hour: '2-digit', minute: '2-digit', hour12: false });\nconst instanceName = body.instance || '';\n\nreturn [{ json: {\n  skip: false,\n  phone,\n  remoteJid,\n  pushName,\n  text: text.trim(),\n  dateStr,\n  timeStr,\n  timestamp: ts,\n  instanceName,\n  brainNote: '07 - Logs/' + dateStr + 'WW'\n} }];\n"
      },
      "id": "code-parse",
      "name": "Parse Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        300
      ]
